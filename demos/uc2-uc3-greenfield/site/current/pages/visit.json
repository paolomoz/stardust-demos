  "sections": [
    { "tag": "section", "className": "hero",           "bgMode": "revival",  "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "VISIT THE BARN. Come to the barn. Saturdays only. Bring your own pew. [Wide photograph: the barn at golden hour.]" },
    { "tag": "section", "className": "what-to-expect", "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "WHAT TO EXPECT. I'll pour four spirits. I'll tell you about each one. The tour is the still, the shed, the mason-jar shelf. ~90 minutes. If you want to ask questions, ask them. If you don't, that's fine too." },
    { "tag": "section", "className": "when",           "bgMode": "revival",  "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "WHEN. Saturdays. Year-round. Two seatings: 2pm and 4pm. Closed during foraging weeks — current schedule listed below." },
    { "tag": "section", "className": "cost",           "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "WHAT IT COSTS. $30 per person. Cash, Venmo, or text-to-pay. Children welcome but no pours." },
    { "tag": "section", "className": "book",           "bgMode": "revival",  "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "HOW TO BOOK. Text Wendell directly. +1 828 555 0143. No form. No platform. Just a phone number." },
    { "tag": "section", "className": "get-there",      "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "HOW TO GET THERE. Wolfpen Holler is on a dirt road off Spring Creek. Last mile is unpaved. High-clearance helpful but not required. Pin: [map link]." }
  ],
