  "sections": [
    { "tag": "section", "className": "hero",      "bgMode": "revival",  "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "THE BOTTLES. Six bottles. Four categories. Every label painted by hand. [Strip image: four hand-painted bottles on a barn shelf.]" },
    { "tag": "section", "className": "amari",     "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "AMARI. (1) PASS THE PLATE — Sunday-morning aperitif amaro. ABV 24%. Sourwood blossom · chicory · magnolia bark. 'Sunday morning. Golden in the glass. Bitter enough that you remember it was made for the offering bowl, not the tip jar. Drink it neat in a small glass before lunch.' WHERE TO BUY · (2) DEACON'S DRAUGHT — off-duty amaro. ABV 26%. Mountain mint · sassafras · black walnut. 'Off-duty.' WHERE TO BUY" },
    { "tag": "section", "className": "bitters",   "bgMode": "revival",  "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "BITTERS. (3) DRINK YE ALL OF IT — cocktail-bitters set, three formats (aromatic, citrus, herbal). 100ml × 3 dasher bottles. ABV 44%. Matthew 26:27. Three dashes minimum. WHERE TO BUY" },
    { "tag": "section", "className": "cordials",  "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "CORDIALS. (4) THE BACKSLIDER — sweet cordial. ABV 18%. Paw-paw · wild persimmon · juniper berry. 'Sunday-school dropouts only.' WHERE TO BUY · (5) TENT REVIVAL — mountain herbal cordial-amaro. ABV 32%. Staghorn sumac · eastern juniper · black walnut hull · ramps (spring only). 'Mountain herbs. Hellfire heat.' WHERE TO BUY" },
    { "tag": "section", "className": "aperitivi", "bgMode": "revival",  "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "APERITIVI. (6) THE NO-SHOW — low-ABV aperitivo, pale pink, sparkling-ready. ABV 11%. Muscadine grape · hibiscus · mountain mint. 'For the pew you didn't sit in.' WHERE TO BUY" }
