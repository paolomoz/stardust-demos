  "sections": [
    { "tag": "section", "className": "hero", "bgMode": "revival", "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "HOLLER & HYMN. Saturday night sin. Sunday morning hymn. Both in one bottle. FIND A PEW · BOOK A SATURDAY TASTING" },
    { "tag": "section", "className": "maker", "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "Made by hand. From a to z. I grew up in a hollow outside Asheville where my grandmother kept a still in the smokehouse and a hymnal on the kitchen table. We never thought of them as different things. — Wendell" },
    { "tag": "section", "className": "the-holler", "bgMode": "revival", "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "Wolfpen Holler, Madison County. Forty minutes outside Asheville. Rhododendron understory, sourwood blossom in late June. The botanicals come from the same woods that grew the rhododendron my grandfather got married under. → THE HOLLER" },
    { "tag": "section", "className": "the-still", "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "The Still. Everything in this bottle was within forty miles of my barn three weeks ago. Built the still in 2019 from a kit. → THE STILL" },
    { "tag": "section", "className": "bottles", "bgMode": "revival", "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "Six bottles. Four categories. Every label painted by hand. PASS THE PLATE · TENT REVIVAL · THE BACKSLIDER → THE BOTTLES" },
    { "tag": "section", "className": "pews", "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "Find a pew. If you're in Asheville, try these. Sermon Bar — Lexington Ave · The Backslider Tavern — RAD · Little Jumbo — downtown · Bull and Beggar — RAD → ALL PEWS" }
  ],
