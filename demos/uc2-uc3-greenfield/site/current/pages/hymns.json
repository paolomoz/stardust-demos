  "sections": [
    { "tag": "section", "className": "hero",                "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "HYMNS. Five ways to drink it. Pick your pew." },
    { "tag": "section", "className": "wayfaring-stranger",  "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "THE WAYFARING STRANGER. 1.5 oz TENT REVIVAL · 1 oz bourbon · 0.5 oz bitter orange · 2 dashes DRINK YE ALL OF IT (aromatic). Stir over ice. Strain neat. Drink alone. Note: Sad." },
    { "tag": "section", "className": "i-saw-the-light",     "bgMode": "revival",  "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "I SAW THE LIGHT. 1.5 oz PASS THE PLATE · 1.5 oz Lillet Blanc · 3 oz soda · lemon twist. Build in a tall glass. Note: Drink it on a porch before the heat of the day. Don't talk much." },
    { "tag": "section", "className": "sunday-morning",      "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "SUNDAY MORNING COMING DOWN. 1.5 oz THE BACKSLIDER · 4 oz cold black coffee · 0.5 oz heavy cream (floated). Build over ice. Note: Slow. Kristofferson would approve." },
    { "tag": "section", "className": "folsom-old-fashioned", "bgMode": "revival", "bgColor": "#1a1410", "colorMode": "#e8d8b8", "childTextSnippet": "THE FOLSOM OLD-FASHIONED. 1.5 oz DEACON'S DRAUGHT · 1.5 oz rye · 1 drop DRINK YE ALL OF IT (aromatic) · expressed orange peel. Stir over ice. Strain over one large rock. Note: For when you have to look someone in the eye." },
    { "tag": "section", "className": "no-show-spritz",      "bgMode": "bulletin", "bgColor": "#e8d8b8", "colorMode": "#1a1410", "childTextSnippet": "THE NO-SHOW SPRITZ. 3 oz THE NO-SHOW · 3 oz dry sparkling wine · 1 oz soda · grapefruit peel. Build over ice. Note: For the pew you didn't sit in." }
